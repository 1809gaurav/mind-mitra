{
  "name": "MindMitra",
  "short_name": "MindMitra",
  "description": "Mental-wellness companion with SOS alerts and journaling.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f172a",
  "theme_color": "#0ea5e9",
  "icons": [
    {
      "src": "/favicon.ico",
      "sizes": "64x64 32x32 24x24 16x16",
      "type": "image/x-icon"
    }
  ],
  "permissions": [
    "notifications",
    "push",
    "storage"
  ]
}
